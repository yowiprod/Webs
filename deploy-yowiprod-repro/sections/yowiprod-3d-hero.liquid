{{ 'yowiprod-3d.css' | asset_url | stylesheet_tag }}

<!-- Frame URLs for JS -->
<script>
  window.__FRAME_DATA_URLS = [
    {%- for i in (1..136) -%}
      {%- if i < 10 -%}{%- assign padded = '00000' | append: i -%}
      {%- elsif i < 100 -%}{%- assign padded = '0000' | append: i -%}
      {%- else -%}{%- assign padded = '000' | append: i -%}{%- endif -%}
      {%- assign filename = 'frame_' | append: padded | append: '.webp' -%}
      "{{ filename | asset_url }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];
</script>

<!-- Loader -->
<div id="yp-loader">
  <div id="yp-loader-wrap">
    <div id="yp-loader-bar"></div>
  </div>
  <p class="yp-loader-text">Cargando...</p>
</div>

<!-- 3D Canvas Background -->
<div id="yp-bg-wrap"><canvas id="yp-bg-canvas"></canvas></div>
<div id="yp-post-frame-backdrop" aria-hidden="true"></div>
<div class="yp-noise-overlay" aria-hidden="true"></div>
<div id="yp-fade-to-black" aria-hidden="true"></div>

<!-- Hero Overlay -->
<div id="yp-overlay">
  <div class="yp-hero" id="yp-hero-content">
    <h1 class="yp-hero-title">{{ section.settings.hero_title }}</h1>
    <p class="yp-hero-subtitle">{{ section.settings.hero_subtitle }}</p>
    <div class="yp-hero-buttons">
      {%- if section.settings.button_1_label != blank -%}
        <a class="yp-cta yp-cta-primary" href="{{ section.settings.button_1_link }}">{{ section.settings.button_1_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_2_label != blank -%}
        <a class="yp-cta yp-cta-secondary" href="{{ section.settings.button_2_link }}">{{ section.settings.button_2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

<!-- Spacer to push Shopify content below the hero -->
<div id="yp-hero-spacer"></div>

<script src="{{ 'yowiprod-3d.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "YowiProd 3D Hero",
  "tag": "section",
  "class": "yp-3d-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Titulo Hero",
      "default": "Producción con identidad."
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Subtitulo Hero",
      "default": "Beats, recursos y servicios para artistas que quieren sonar reales."
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Boton 1 texto",
      "default": "Escuchar Beats"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Boton 1 enlace"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Boton 2 texto",
      "default": "Trabajar conmigo"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Boton 2 enlace"
    }
  ],
  "presets": [
    {
      "name": "YowiProd 3D Hero"
    }
  ]
}
{% endschema %}
