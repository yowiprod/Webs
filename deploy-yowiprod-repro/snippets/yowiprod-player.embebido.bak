{%- comment -%}
  Reproductor de beats YOWIPROD · barra inferior desplegable (player + playlist)
  Datos embebidos (35 beats). Para versión dinámica: leer product.metafields.custom.preview_audio
{%- endcomment -%}
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap');
#yp-root{
  --yp-ink:#f4ecdb; --yp-mut:rgba(244,236,219,.6); --yp-mut2:rgba(244,236,219,.34);
  --yp-gold:#cfa24a; --yp-gold-lt:#f3d997;
  --yp-glass:rgba(207,162,74,.07); --yp-glass-h:rgba(207,162,74,.13);
  --yp-panel:rgba(16,13,9,.72); --yp-line:rgba(196,201,207,.16);
  --yp-silver:#c4c9cf; --yp-silver-dim:rgba(196,201,207,.72);
  font-family:'Inter',system-ui,sans-serif;
}
#yp-root *{box-sizing:border-box}
#yp-root .yp-scrim{position:fixed;inset:0;z-index:2147483640;background:rgba(0,0,0,.45);opacity:0;visibility:hidden;transition:.3s}
#yp-root .yp-scrim.yp-open{opacity:1;visibility:visible}
#yp-root .yp-sheet{position:fixed;left:0;right:0;bottom:66px;z-index:2147483645;max-height:0;overflow:hidden;
  background:var(--yp-panel);backdrop-filter:blur(26px);-webkit-backdrop-filter:blur(26px);border-top:1px solid var(--yp-line);
  transition:max-height .4s cubic-bezier(.25,.8,.25,1);box-shadow:0 -30px 60px -20px rgba(0,0,0,.7)}
#yp-root .yp-sheet.yp-open{max-height:72vh}
#yp-root .yp-inner{max-width:1000px;margin:0 auto;padding:16px clamp(16px,5vw,34px) 18px}
#yp-root .yp-shead{display:flex;align-items:center;gap:14px;margin-bottom:12px;flex-wrap:wrap}
#yp-root .yp-shead h2{font-family:'Cinzel';font-size:14px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--yp-gold);margin:0}
#yp-root .yp-count{color:var(--yp-mut2);font-size:12.5px}
#yp-root .yp-search{margin-left:auto;display:flex;align-items:center;gap:8px;background:var(--yp-glass);border:1px solid var(--yp-line);border-radius:9px;padding:8px 12px;width:min(260px,55vw)}
#yp-root .yp-search:focus-within{border-color:var(--yp-gold)}
#yp-root .yp-search svg{flex:none;opacity:.5;color:var(--yp-gold)}
#yp-root .yp-search input{background:none;border:none;outline:none;color:var(--yp-ink);font-size:13.5px;width:100%;font-family:inherit}
#yp-root .yp-search input::placeholder{color:var(--yp-mut2)}
#yp-root .yp-filters{display:flex;gap:6px;flex-wrap:wrap;width:100%}
#yp-root .yp-chip{background:var(--yp-glass);border:1px solid var(--yp-line);color:var(--yp-mut);padding:5px 12px;border-radius:99px;font-size:12px;font-weight:500;cursor:pointer;transition:.18s;white-space:nowrap;font-family:inherit}
#yp-root .yp-chip:hover{color:var(--yp-ink);border-color:var(--yp-gold)}
#yp-root .yp-chip.yp-on{background:linear-gradient(180deg,var(--yp-gold-lt),var(--yp-gold));color:#0a0806;border-color:transparent;font-weight:600}
#yp-root .yp-list{margin-top:10px;max-height:calc(72vh - 130px);overflow-y:auto;display:flex;flex-direction:column;gap:2px;padding-right:4px}
#yp-root .yp-list::-webkit-scrollbar{width:7px}#yp-root .yp-list::-webkit-scrollbar-thumb{background:var(--yp-line);border-radius:9px}
#yp-root .yp-row{display:grid;grid-template-columns:24px 42px 1fr auto;align-items:center;gap:13px;padding:8px 10px;border-radius:10px;cursor:pointer;border:1px solid transparent;transition:.12s}
#yp-root .yp-row:hover{background:var(--yp-glass)}
#yp-root .yp-row.yp-active{background:var(--yp-glass-h);border-color:var(--yp-line)}
#yp-root .yp-row.yp-dis{opacity:.36;cursor:default}#yp-root .yp-row.yp-dis:hover{background:transparent}
#yp-root .yp-num{color:var(--yp-silver-dim);font-size:12.5px;text-align:center}
#yp-root .yp-row.yp-active .yp-num{color:var(--yp-gold)}
#yp-root .yp-art{width:42px;height:42px;border-radius:7px;object-fit:cover;background:rgba(207,162,74,.07);flex:none}
#yp-root .yp-rm{min-width:0}
#yp-root .yp-rm .yp-t{font-weight:600;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--yp-ink)}
#yp-root .yp-row.yp-active .yp-rm .yp-t{color:var(--yp-gold-lt)}
#yp-root .yp-rm .yp-s{color:var(--yp-silver-dim);font-size:11.5px;margin-top:1px;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
#yp-root .yp-tag{font-size:9.5px;letter-spacing:.5px;text-transform:uppercase;padding:2px 6px;border-radius:5px;font-weight:600}
#yp-root .yp-tag.yp-free{background:rgba(207,162,74,.16);color:var(--yp-gold-lt)}
#yp-root .yp-tag.yp-soon{background:rgba(244,236,219,.08);color:var(--yp-mut)}
#yp-root .yp-rr{color:var(--yp-silver-dim);font-size:12px;font-variant-numeric:tabular-nums;letter-spacing:.3px}
#yp-root .yp-bar{position:fixed;left:0;right:0;bottom:0;z-index:2147483646;height:66px;background:var(--yp-panel);backdrop-filter:blur(26px);-webkit-backdrop-filter:blur(26px);border-top:1px solid var(--yp-line)}
#yp-root .yp-prog{position:absolute;top:0;left:0;right:0;height:3px;background:rgba(244,236,219,.14);cursor:pointer}
#yp-root .yp-fill{height:100%;width:0;background:linear-gradient(90deg,var(--yp-gold),var(--yp-gold-lt));position:relative}
#yp-root .yp-fill::after{content:'';position:absolute;right:-5px;top:50%;transform:translateY(-50%);width:10px;height:10px;border-radius:50%;background:var(--yp-gold-lt);box-shadow:0 0 8px var(--yp-gold);opacity:0;transition:.15s}
#yp-root .yp-prog:hover .yp-fill::after{opacity:1}
#yp-root .yp-barin{max-width:1000px;margin:0 auto;height:100%;display:flex;align-items:center;gap:14px;padding:0 clamp(14px,5vw,34px)}
#yp-root .yp-now{display:flex;align-items:center;gap:11px;min-width:0;width:clamp(150px,30vw,280px);cursor:pointer}
#yp-root .yp-now img{width:44px;height:44px;border-radius:8px;object-fit:cover;flex:none;background:rgba(207,162,74,.08)}
#yp-root .yp-now .yp-t{font-weight:600;font-size:13.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--yp-ink)}
#yp-root .yp-now .yp-s{color:var(--yp-mut);font-size:11.5px;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
#yp-root .yp-ctr{display:flex;align-items:center;gap:8px;margin:0 auto}
#yp-root .yp-cbtn{background:none;border:none;color:var(--yp-ink);cursor:pointer;display:grid;place-items:center;transition:.15s;border-radius:50%;padding:0}
#yp-root .yp-cbtn:hover{color:var(--yp-gold);transform:scale(1.1)}
#yp-root .yp-cbtn.yp-main{width:42px;height:42px;background:linear-gradient(180deg,var(--yp-gold-lt),var(--yp-gold));color:#0a0806;box-shadow:0 6px 18px -6px rgba(207,162,74,.6)}
#yp-root .yp-cbtn.yp-main:hover{filter:brightness(1.08);transform:scale(1.06)}
#yp-root .yp-time{font-size:11.5px;color:var(--yp-silver-dim);font-variant-numeric:tabular-nums;width:84px;text-align:right}
#yp-root .yp-vol{display:flex;align-items:center;gap:7px;width:96px;color:var(--yp-mut)}
#yp-root .yp-vol input{width:100%;accent-color:var(--yp-gold);cursor:pointer}
#yp-root .yp-toggle{background:var(--yp-glass);border:1px solid var(--yp-line);color:var(--yp-gold);cursor:pointer;width:38px;height:34px;border-radius:9px;display:grid;place-items:center;transition:.18s}
#yp-root .yp-toggle:hover{background:var(--yp-glass-h)}
#yp-root .yp-toggle svg{transition:transform .35s}
#yp-root .yp-toggle.yp-open svg{transform:rotate(180deg)}
@media(max-width:720px){
  #yp-root .yp-now{width:auto}#yp-root .yp-now .yp-s{display:none}#yp-root .yp-time{display:none}#yp-root .yp-vol{display:none}
  #yp-root .yp-search{width:100%;order:5;margin:0}
}
</style>

<div id="yp-root">
  <div class="yp-scrim" id="yp-scrim"></div>
  <div class="yp-sheet" id="yp-sheet">
    <div class="yp-inner">
      <div class="yp-shead">
        <h2>Beats</h2><span class="yp-count" id="yp-count"></span>
        <label class="yp-search">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input id="yp-q" placeholder="Buscar beat, BPM…" autocomplete="off">
        </label>
        <div class="yp-filters" id="yp-filters"></div>
      </div>
      <div class="yp-list" id="yp-listbox"></div>
    </div>
  </div>
  <div class="yp-bar">
    <div class="yp-prog" id="yp-prog"><div class="yp-fill" id="yp-fill"></div></div>
    <div class="yp-barin">
      <div class="yp-now" id="yp-now" title="Abrir lista">
        <img id="yp-art" alt="">
        <div style="min-width:0"><div class="yp-t" id="yp-title">—</div><div class="yp-s" id="yp-sub">Pulsa play</div></div>
      </div>
      <div class="yp-ctr">
        <button class="yp-cbtn" id="yp-prev" title="Anterior"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg></button>
        <button class="yp-cbtn yp-main" id="yp-play" title="Play/Pausa"><svg id="yp-ic" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></button>
        <button class="yp-cbtn" id="yp-next" title="Siguiente"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 6h2v12h-2zM6 18l8.5-6L6 6z"/></svg></button>
      </div>
      <div class="yp-time"><span id="yp-cur">0:00</span> / <span id="yp-dur">0:00</span></div>
      <div class="yp-vol">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" style="opacity:.6;flex:none"><path d="M3 9v6h4l5 5V4L7 9z"/></svg>
        <input type="range" id="yp-volr" min="0" max="1" step="0.01" value="0.85">
      </div>
      <button class="yp-toggle" id="yp-toggle" title="Desplegar lista"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M7 14l5-5 5 5z"/></svg></button>
    </div>
  </div>
  <audio id="yp-audio"></audio>
</div>

<script>
(function(){
  var BEATS = [{"title": "DIAMANTES", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_DIAMANTES_97BPM_F_MAJOR.mp3?v=1770746113", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/DiamantesCoverArt.png?v=1770324772", "bpm": "97", "key": "Eb minor", "type": "", "free": false}, {"title": "2006", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW.mp3?v=1771412184", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/2006.png?v=1771412019", "bpm": null, "key": "Gb minor", "type": "Beat", "free": false}, {"title": "ACTUA", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_ACTUA_102BPM.mp3?v=1772550943", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/ACTUA.png?v=1772550821", "bpm": "102", "key": "Eb minor", "type": "Beat", "free": false}, {"title": "AMADO", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_AMADO.mp3?v=1772112268", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/AAMADO.png?v=1772112181", "bpm": null, "key": "C# minor", "type": "Beat", "free": false}, {"title": "AMANTES", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/AMANTES_122BPM_F_m_PRW.mp3?v=1770740145", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/ARTCOVERAMANTES.png?v=1770326174", "bpm": "122", "key": "F# minor", "type": "Beat", "free": false}, {"title": "AMOR Y ROSAS", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_AMOR_Y_ROSAS.mp3?v=1771523507", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/AMORYROSAS.png?v=1771523486", "bpm": null, "key": "Eb minor", "type": "Beat", "free": false}, {"title": "ANGEL", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/RRW-ANGEL-144BPM-Em.mp3?v=1771855552", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/aNGEL.png?v=1771855309", "bpm": "144", "key": "E minor", "type": "Beat", "free": false}, {"title": "ARAÑA", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_ARANA_160_BPM.mp3?v=1772038161", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/ARANAA.png?v=1772037923", "bpm": null, "key": "D# minor", "type": "Beat", "free": false}, {"title": "BABY", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_BABY_190.mp3?v=1771784758", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/baby.png?v=1771784377", "bpm": null, "key": "A minor", "type": "Beat", "free": false}, {"title": "BANG", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_BANG.mp3?v=1771415841", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/BANG.png?v=1771414736", "bpm": null, "key": "A minor", "type": "Beat", "free": false}, {"title": "CHAOS", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_CHAOS_90bpm_a_minor.mp3?v=1770819724", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/RNB.png?v=1770142598", "bpm": "90", "key": "A minor", "type": "Beat", "free": false}, {"title": "COMO HIENAS", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_hienas_166_BPM.mp3?v=1772029734", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/COMOHIENAS_ca8ed396-1439-442f-9e0b-50071c457610.png?v=1772030824", "bpm": null, "key": "C# minor", "type": "Beat", "free": false}, {"title": "CONSECUENCIA", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_CONSECUENCIA.mp3?v=1771497169", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/consecuencia.png?v=1771494491", "bpm": null, "key": "A# MAJOR", "type": "Beat", "free": false}, {"title": "CORNER HOUSE", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_CORNER.mp3?v=1771425590", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/corner.png?v=1771424989", "bpm": null, "key": "Ab minor", "type": "Beat", "free": false}, {"title": "DINERO", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_DINERO_126bpm.mp3?v=1772982527", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/MNY.png?v=1772983335", "bpm": "126", "key": "D# minor", "type": "Beat", "free": false}, {"title": "DREAM", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/DREAM_120BPM_Dm.mp3?v=1770651527", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/DREAM.png?v=1770303610", "bpm": "120", "key": "D minor", "type": "Beat", "free": false}, {"title": "ELLA", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_ELLA.mp3?v=1771518829", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/ellaart.png?v=1771518372", "bpm": null, "key": "Gb minor", "type": "Beat", "free": false}, {"title": "ERES MALA", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_MALA_95BPM_Fm.mp3?v=1771695406", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/ERESMALA.png?v=1771695249", "bpm": "95", "key": "F minor", "type": "Beat", "free": false}, {"title": "FANTASMA", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/SIN_SENAL_194BPM_Bm_DEMO.mp3?v=1770640279", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/COVERARTFANTASMA.png?v=1770321392", "bpm": "194", "key": "B minor", "type": "Beat", "free": false}, {"title": "LA VITA", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW-LA-VITA-192-BPM.mp3?v=1772534910", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/LAVITA.png?v=1772534366", "bpm": null, "key": "A minor", "type": "Beat", "free": false}, {"title": "LEAN AND DROPS", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_LEAN_AND_DROPS_200BPM_Fm.mp3?v=1772792785", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/LEANANDDROPS.png?v=1772792032", "bpm": "200", "key": "F minor", "type": "Beat", "free": false}, {"title": "LUZ EN LA OSCURIDAD", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_DARKNES.mp3?v=1772126446", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/LUZENLAOSCURIDAD.png?v=1772126472", "bpm": null, "key": "B minor", "type": "Beat", "free": false}, {"title": "MI YO", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_MIYO.mp3?v=1771422239", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/MIYO.png?v=1771422234", "bpm": null, "key": "G minor", "type": "Beat", "free": false}, {"title": "MILF", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_190BPM_AMINOR_MILF_AFRO_DETROIT.mp3?v=1771330692", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/MILF.png?v=1771330480", "bpm": "190", "key": "A minor", "type": "Beat", "free": false}, {"title": "MILLONARIO", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_MILLONARIO_101BPM_Gm.mp3?v=1771605365", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/MILLONARIO.png?v=1771605005", "bpm": "101", "key": "G minor", "type": "Beat", "free": false}, {"title": "MIS ASUNTOS", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/DRY_AGUACATE_98BPM_DEMO.mp3?v=1770575862", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/CoverArtworkMASASUNTOS.png?v=1770322581", "bpm": "98", "key": "B minor", "type": "Beat", "free": false}, {"title": "PEGA", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_PEGA_BPM127_Aminor.mp3?v=1771527707", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PEGA.png?v=1771527420", "bpm": "127", "key": "A minor", "type": "Beat", "free": false}, {"title": "PERSECUCIÓN", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_PERSECUCION_135_D_m.mp3?v=1771439431", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/persecucion.png?v=1771438377", "bpm": null, "key": "D# minor", "type": "Beat", "free": false}, {"title": "QUEDAN SEGUNDOS", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_QUEDAN_SEGUNDOS_172BPM_Ebm.mp3?v=1780309412", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/quedansegundosdetroit.png?v=1771334159", "bpm": "172", "key": "D# minor", "type": "Beat", "free": false}, {"title": "QUIEN SOY", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_QUIEN_SOY.mp3?v=1771612405", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/QUIENSOY.png?v=1771611855", "bpm": null, "key": "F minor", "type": "Beat", "free": false}, {"title": "RETRO", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_AUDIO.mp3?v=1770732525", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/ARTCoverRETRO.png?v=1770325431", "bpm": null, "key": "Eb minor", "type": "Beat", "free": false}, {"title": "SECRETOS", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_SECRETO_160bpm_Dm.mp3?v=1772977005", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/secretos.png?v=1772976298", "bpm": "160", "key": "D minor", "type": "Beat", "free": false}, {"title": "STILL JURADO", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/STILL_Jurado_preview_Fminor_160bpm.mp3?v=1778847350", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/Stilljurado.png?v=1778847328", "bpm": "160", "key": "F minor", "type": "Beat", "free": false}, {"title": "VAGANDO", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRW_VAGANDO.mp3?v=1772115445", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/VAGANDO.png?v=1772115134", "bpm": null, "key": "D minor", "type": "Beat", "free": false}, {"title": "Your Shadow", "mp3": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/your_shadow_141bpm_d_m_demo.mp3?v=1770656426", "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/yoirshadow.png?v=1770197552", "bpm": "141", "key": "Eb minor", "type": "Beat", "free": false}, {"title": "Beat \"2006\" — GRATIS", "mp3": null, "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/2006_7acb3ef6-be9c-4141-8fa5-29b1d5616088.png?v=1779706018", "bpm": "127", "key": "Gb minor", "type": "Beat", "free": true}, {"title": "Beat \"RETRO\" — GRATIS", "mp3": null, "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/retro.png?v=1779706483", "bpm": "174", "key": "C# minor", "type": "Beat", "free": true}, {"title": "Beat \"Your Shadow\" — GRATIS", "mp3": null, "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/your-shadow.png?v=1779706706", "bpm": "141", "key": "D# minor", "type": "Beat", "free": true}, {"title": "FROM PAIN TO POWER VOL1", "mp3": null, "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/FROMPAINTOPOWEVOL.1.png?v=1770143140", "bpm": null, "key": null, "type": "DRUMKITS", "free": true}, {"title": "ASESORIA 1:1", "mp3": null, "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/asesoria_1d686b75-04af-4265-9652-6c05760f839c.png?v=1770375048", "bpm": null, "key": null, "type": "HIGH TICKET", "free": false}, {"title": "Ghostwriting · Letra personalizada (1:1)", "mp3": null, "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/Letrapersonalizada_11.png?v=1770903692", "bpm": null, "key": null, "type": "HIGH TICKET", "free": false}, {"title": "Producción personalizada 1:1 desde cero", "mp3": null, "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/PRODPERSONLAIZADA.png?v=1770374167", "bpm": null, "key": null, "type": "HIGH TICKET", "free": false}, {"title": "FREE MIDI CREATION KIT VOLUMEN 1", "mp3": null, "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/FREEMIDICREATIONKITVOLUMEN1IMG_3257f05e-bb8b-48b1-b2bf-3068be52ee80.png?v=1773312160", "bpm": null, "key": null, "type": "Loops y Midis", "free": true}, {"title": "MIDI CREATION KIT VOLUMEN 1", "mp3": null, "img": "https://cdn.shopify.com/s/files/1/0988/6852/7392/files/MIDICREATIONKITVOLUMEN1IMG.png?v=1773312183", "bpm": null, "key": null, "type": "Loops y Midis", "free": false}];
  var root=document.getElementById('yp-root');
  var $=function(s){return root.querySelector(s);};
  var audio=$('#yp-audio'),sheet=$('#yp-sheet'),scrim=$('#yp-scrim'),toggle=$('#yp-toggle');
  var queue=[],cur=-1,filter='all',search='';
  var types=[];BEATS.forEach(function(b){if(b.type&&types.indexOf(b.type)<0)types.push(b.type);});
  var fdefs=[{k:'all',l:'Todos'},{k:'play',l:'Con audio'},{k:'free',l:'Gratis'}].concat(types.map(function(t){return{k:'type:'+t,l:t};}));
  $('#yp-filters').innerHTML=fdefs.map(function(f){return '<button class="yp-chip'+(f.k==='all'?' yp-on':'')+'" data-k="'+f.k+'">'+f.l+'</button>';}).join('');
  $('#yp-filters').addEventListener('click',function(e){var c=e.target.closest('.yp-chip');if(!c)return;
    root.querySelectorAll('.yp-chip').forEach(function(x){x.classList.remove('yp-on');});c.classList.add('yp-on');filter=c.dataset.k;render();});
  $('#yp-q').addEventListener('input',function(e){search=e.target.value.toLowerCase().trim();render();});
  function visible(){return BEATS.filter(function(b){
    if(filter==='play'&&!b.mp3)return false;
    if(filter==='free'&&!b.free)return false;
    if(filter.indexOf('type:')===0&&b.type!==filter.slice(5))return false;
    if(search){var hay=(b.title+' '+(b.bpm||'')+' '+(b.key||'')+' '+b.type).toLowerCase();if(hay.indexOf(search)<0)return false;}
    return true;});}
  function render(){
    queue=visible();
    $('#yp-count').textContent=queue.filter(function(b){return b.mp3;}).length+' con audio · '+queue.length;
    $('#yp-listbox').innerHTML=queue.map(function(b,i){
      var tags=[b.free?'<span class="yp-tag yp-free">GRATIS</span>':'',!b.mp3?'<span class="yp-tag yp-soon">sin preview</span>':''].filter(Boolean).join('');
      var sub=[tags,b.type?'<span>'+b.type+'</span>':''].filter(Boolean).join('');
      var bpm=b.bpm?b.bpm+' BPM':'';var key=b.key?' · '+b.key:'';
      var art=b.img?'<img class="yp-art" src="'+b.img+'" loading="lazy" alt="">':'<div class="yp-art"></div>';
      return '<div class="yp-row '+(b.mp3?'':'yp-dis')+' '+(cur>-1&&queue[cur]===b?'yp-active':'')+'" data-i="'+i+'">'+
        '<div class="yp-num">'+(i+1)+'</div>'+art+
        '<div class="yp-rm"><div class="yp-t">'+b.title+'</div><div class="yp-s">'+sub+'</div></div>'+
        '<div class="yp-rr">'+bpm+key+'</div></div>';
    }).join('')||'<div style="color:var(--yp-mut);padding:24px;text-align:center">Sin resultados.</div>';
  }
  $('#yp-listbox').addEventListener('click',function(e){var r=e.target.closest('.yp-row');if(!r||r.classList.contains('yp-dis'))return;load(parseInt(r.dataset.i),true);});
  function openSheet(o){sheet.classList.toggle('yp-open',o);scrim.classList.toggle('yp-open',o);toggle.classList.toggle('yp-open',o);}
  toggle.onclick=function(){openSheet(!sheet.classList.contains('yp-open'));};
  $('#yp-now').onclick=function(){openSheet(!sheet.classList.contains('yp-open'));};
  scrim.onclick=function(){openSheet(false);};
  function load(i,playNow){
    var b=queue[i];if(!b||!b.mp3)return;cur=i;
    $('#yp-art').src=b.img||'';$('#yp-title').textContent=b.title;
    $('#yp-sub').textContent=[b.free?'GRATIS':'Premium',b.bpm?b.bpm+' BPM':'',b.key||''].filter(Boolean).join(' · ');
    audio.src=b.mp3;if(playNow)audio.play().catch(function(){});render();
  }
  $('#yp-play').onclick=function(){if(!audio.src){var f=-1;queue.forEach(function(b,i){if(f<0&&b.mp3)f=i;});if(f>=0)load(f,true);return;}audio.paused?audio.play():audio.pause();};
  function setIc(p){$('#yp-ic').innerHTML=p?'<path d="M6 5h4v14H6zm8 0h4v14h-4z"/>':'<path d="M8 5v14l11-7z"/>';}
  audio.onplay=function(){setIc(true);};audio.onpause=function(){setIc(false);};
  function step(d){var n=cur;for(var k=0;k<queue.length;k++){n=(n+d+queue.length)%queue.length;if(queue[n].mp3){load(n,true);return;}}}
  $('#yp-next').onclick=function(){step(1);};
  $('#yp-prev').onclick=function(){if(audio.currentTime>3){audio.currentTime=0;return;}step(-1);};
  audio.onended=function(){step(1);};
  function fmt(s){return isNaN(s)?'0:00':Math.floor(s/60)+':'+String(Math.floor(s%60)).padStart(2,'0');}
  var prog=$('#yp-prog');
  audio.ontimeupdate=function(){$('#yp-fill').style.width=(audio.currentTime/audio.duration*100||0)+'%';$('#yp-cur').textContent=fmt(audio.currentTime);};
  audio.onloadedmetadata=function(){$('#yp-dur').textContent=fmt(audio.duration);};
  prog.onclick=function(e){var r=prog.getBoundingClientRect();if(audio.duration)audio.currentTime=(e.clientX-r.left)/r.width*audio.duration;};
  $('#yp-volr').oninput=function(e){audio.volume=e.target.value;};audio.volume=0.85;
  document.addEventListener('keydown',function(e){if(e.target.tagName==='INPUT')return;
    if(e.code==='Space'){e.preventDefault();$('#yp-play').click();}
    if(e.code==='ArrowRight')$('#yp-next').click();if(e.code==='ArrowLeft')$('#yp-prev').click();
    if(e.code==='Escape')openSheet(false);});
  render();var first=-1;queue.forEach(function(b,i){if(first<0&&b.mp3)first=i;});if(first>=0)load(first,false);
})();
</script>
