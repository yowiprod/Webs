      "settings": {
        "custom_liquid": "{%- comment -%}\n  YOWIPROD — Bloque \"Pack Gratis\" para incrustar dentro de /pages/gratis (LOW COST)\n  Pegar como sección \"Liquid personalizado\" en theme editor.\n  COMPACTO: solo hero + 3 beats + bonus + CTA. Sin FAQ ni license (esos van en el email).\n  Recomendado: colocar justo después del Banner de imagen LOW COST.\n  Última actualización: 2026-05-24 v2\n{%- endcomment -%}\n\n<style>\n  /* Scope .yp-pack para no contaminar el tema */\n  .yp-pack *{box-sizing:border-box}\n  .yp-pack{font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;line-height:1.5;-webkit-font-smoothing:antialiased;color:#121212;margin:0;padding:0}\n  .yp-pack .wrap{max-width:1100px;margin:0 auto;padding:0 24px}\n\n  /* HERO compacto (transparente, texto claro sobre fondo oscuro del tema) */\n  .yp-pack .hero{padding:50px 0 40px;text-align:center}\n  .yp-pack .badge{display:inline-block;background:#efb810;color:#121212 !important;padding:6px 14px;border-radius:30px;font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;margin-bottom:18px}\n  .yp-pack .hero h2{font-size:clamp(30px,5vw,52px);line-height:1.05;font-weight:900;letter-spacing:-0.03em;margin:0 auto 16px;max-width:820px;color:#ffffff !important}\n  .yp-pack .hero h2 .accent{color:#efb810 !important}\n  .yp-pack .hero .sub{font-size:17px;max-width:620px;margin:0 auto 28px;line-height:1.5;color:#cccccc !important}\n  .yp-pack .hero .sub strong{font-weight:700;color:#efb810 !important}\n  .yp-pack .cta-primary,.yp-pack .cta-primary:link,.yp-pack .cta-primary:visited{display:inline-block;background:#efb810 !important;color:#121212 !important;padding:16px 36px;border-radius:6px;font-weight:900;font-size:16px;letter-spacing:0.5px;text-decoration:none !important;transition:transform 0.15s;box-shadow:0 4px 0 rgba(239,184,16,0.3)}\n  .yp-pack .cta-primary:hover{transform:translateY(-2px);color:#121212 !important;text-decoration:none !important;box-shadow:0 6px 20px rgba(239,184,16,0.4)}\n  .yp-pack .cta-meta{display:block;margin-top:14px;font-size:12px;color:#888}\n\n  /* BEATS GRID (sin fondo, hereda del tema) */\n  .yp-pack .beats-section{padding:40px 0 60px}\n  .yp-pack .eyebrow{font-size:11px;color:#efb810 !important;letter-spacing:3px;text-transform:uppercase;font-weight:800;margin-bottom:10px;text-align:center}\n  .yp-pack .section-title{font-size:clamp(24px,3.5vw,34px);font-weight:900;letter-spacing:-0.02em;margin:0 auto 30px;color:#ffffff !important;text-align:center;max-width:680px}\n\n  .yp-pack .beats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:30px}\n  .yp-pack .beat-card,.yp-pack .beat-card:link,.yp-pack .beat-card:visited{background:#121212 !important;border:1px solid #2a2a2a;border-radius:12px;padding:22px;transition:border-color 0.2s,transform 0.2s,box-shadow 0.2s;display:block;text-decoration:none !important;color:#ffffff !important}\n  .yp-pack .beat-card:hover{border-color:#efb810;transform:translateY(-3px);box-shadow:0 10px 30px rgba(239,184,16,0.15);color:#ffffff !important;text-decoration:none !important}\n  .yp-pack .beat-tag{display:inline-block;background:#efb810 !important;color:#121212 !important;padding:4px 10px;border-radius:4px;font-size:10px;letter-spacing:1.5px;font-weight:800;margin-bottom:12px}\n  .yp-pack .beat-card h3{font-size:22px;font-weight:900;margin:0 0 6px;letter-spacing:-0.01em;color:#ffffff !important}\n  .yp-pack .beat-meta{font-size:12px;color:#aaaaaa !important;margin:0 0 14px;font-weight:600}\n  .yp-pack .beat-price{font-size:13px;color:#999 !important;margin:0}\n  .yp-pack .beat-price s{color:#666 !important}\n  .yp-pack .beat-price strong{color:#121212 !important;font-weight:900;margin-left:6px;background:#efb810;padding:3px 8px;border-radius:3px}\n  @media(max-width:780px){.yp-pack .beats-grid{grid-template-columns:1fr}}\n\n  /* BONUS */\n  .yp-pack .bonus{background:#121212;color:#ffffff;border-radius:14px;padding:32px;margin-top:26px;display:grid;grid-template-columns:1fr auto;gap:24px;align-items:center;border:2px solid #efb810;position:relative}\n  .yp-pack .bonus::before{content:\"⭐\";position:absolute;top:-16px;left:24px;background:#efb810;width:32px;height:32px;border-radius:50%;display:grid;place-items:center;font-size:16px}\n  .yp-pack .badge-bonus{display:inline-block;background:#efb810;color:#121212 !important;padding:4px 10px;border-radius:4px;font-size:10px;letter-spacing:2px;font-weight:800;margin-bottom:10px}\n  .yp-pack .bonus h3{font-size:24px;font-weight:900;margin:0 0 8px;letter-spacing:-0.01em;color:#ffffff}\n  .yp-pack .bonus p{color:#cccccc;font-size:14px;margin:0;line-height:1.5}\n  .yp-pack .bonus p strong{color:#efb810}\n  .yp-pack .cta-bonus,.yp-pack .cta-bonus:link,.yp-pack .cta-bonus:visited{background:#efb810 !important;color:#121212 !important;padding:14px 26px;border-radius:6px;font-weight:900;text-decoration:none !important;white-space:nowrap;transition:transform 0.15s;font-size:14px}\n  .yp-pack .cta-bonus:hover{transform:translateY(-2px);color:#121212 !important;text-decoration:none !important}\n  @media(max-width:680px){.yp-pack .bonus{grid-template-columns:1fr;text-align:center;padding:28px 20px}}\n</style>\n\n<div class=\"yp-pack\">\n\n  <!-- HERO -->\n  <div class=\"hero\">\n    <div class=\"wrap\">\n      <span class=\"badge\">100% Gratis · Sin newsletter de basura</span>\n      <h2>Antes de explorar el catálogo, <span class=\"accent\">llévate 3 beats gratis</span></h2>\n      <p class=\"sub\">3 beats <strong>untagged</strong> + drumkit completo. Material real que uso con artistas urbanos. <strong>Valor: 150€.</strong> Tu precio: tu email.</p>\n      <a href=\"#yp-pack-beats\" class=\"cta-primary\">Reclamar mi pack gratis →</a>\n      <span class=\"cta-meta\">Descarga inmediata · MP3 limpios · 47 segundos</span>\n    </div>\n  </div>\n\n  <!-- BEATS -->\n  <div class=\"beats-section\" id=\"yp-pack-beats\">\n    <div class=\"wrap\">\n      <div class=\"eyebrow\">— Qué te llevas (gratis)</div>\n      <h3 class=\"section-title\">3 beats producidos para artistas urbanos</h3>\n\n      <div class=\"beats-grid\">\n        <a href=\"/products/beat-2006-gratis-lead-magnet\" class=\"beat-card\">\n          <span class=\"beat-tag\">TRAP · R&amp;B OSCURO</span>\n          <h3>Beat \"2006\"</h3>\n          <p class=\"beat-meta\">127 BPM · Gb minor</p>\n          <p class=\"beat-price\"><s>38,50€</s> <strong>GRATIS</strong></p>\n        </a>\n        <a href=\"/products/beat-retro-gratis-lead-magnet\" class=\"beat-card\">\n          <span class=\"beat-tag\">BOOM BAP · CASSETTE</span>\n          <h3>Beat \"RETRO\"</h3>\n          <p class=\"beat-meta\">174 BPM · C# minor</p>\n          <p class=\"beat-price\"><s>37,50€</s> <strong>GRATIS</strong></p>\n        </a>\n        <a href=\"/products/beat-your-shadow-gratis-lead-magnet\" class=\"beat-card\">\n          <span class=\"beat-tag\">DRILL · 808s PESADOS</span>\n          <h3>Beat \"Your Shadow\"</h3>\n          <p class=\"beat-meta\">141 BPM · D# minor</p>\n          <p class=\"beat-price\"><s>39,99€</s> <strong>GRATIS</strong></p>\n        </a>\n      </div>\n\n      <!-- BONUS -->\n      <div class=\"bonus\">\n        <div>\n          <span class=\"badge-bonus\">+ BONUS GRATIS</span>\n          <h3>FROM PAIN TO POWER VOL.1</h3>\n          <p>Drumkit completo: 6 drums + 6 loops + 2 vocals firmados @yowiprod. <strong>Valor 6,99€.</strong></p>\n        </div>\n        <a href=\"/products/from-pain-to-power-vol1\" class=\"cta-bonus\">Lo reclamo →</a>\n      </div>\n    </div>\n  </div>\n\n</div>",
